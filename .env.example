DJANGO_SECRET_KEY=change_me
DJANGO_ENV=production
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,backend,frontend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DJANGO_CORS_ALLOW_ALL_ORIGINS=0
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_SESSION_COOKIE_SECURE=0
RQ_REDIS_URL=redis://redis:6379/0
RQ_DEFAULT_TIMEOUT=300
OPENROUTER_API_KEY=
AI_OPENROUTER_MODELS=openai/gpt-oss-120b:free,qwen/qwen3.6-plus:free,qwen/qwen3-coder:free,inclusionai/ling-2.6-flash:free,inclusionai/ling-2.6-1t:free,google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,nvidia/nemotron-3-super-120b-a12b:free,nvidia/nemotron-3-nano-30b-a3b:free,openai/gpt-oss-20b:free,z-ai/glm-4.5-air:free,openrouter/free
AI_TIMEOUT_MS=12000
AI_MAX_RETRIES=2
